set durum = "bekliyor"
match durum:
    "çalışıyor":
        say "aktif"
    "bekliyor", "duraklatıldı":
        say "pasif"
    _:
        say "bilinmeyen"
match 42:
    1:
        say "bir"
    _:
        say "varsayılan"
match [1, 2]:
    [1, 2]:
        say "liste eşleşti"
set sayaç = 0
for i in range(5):
    match i:
        1, 3:
            continue
        4:
            break
    sayaç += 1
say sayaç
fn sınıflandır(n):
    match n:
        0:
            return "sıfır"
        _:
            return "başka"
say sınıflandır(0), sınıflandır(9)

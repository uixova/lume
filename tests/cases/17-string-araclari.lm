use text: split, join, upper, lower, trim, replace, starts_with, ends_with
say split("elma,armut,kiraz", ",")
say split("şey", "")
say join(["a", 1, true], "-")
say upper("merhaba işık"), lower("MERHABA IŞIK")
say trim("  x  ")
say replace("aaa", "a", "bb")
say contains("merhaba", "erha"), contains([1, 2], 2), contains({"a": 1}, "a")
say find("şeker", "ker"), find([5, 6], 6), find("abc", "z")
say starts_with("lume", "lu"), ends_with("test.lm", ".lm")
say slice("merhaba", 1, 4), slice("merhaba", -3), slice([1, 2, 3, 4], 1, 3)
say reverse("şeker"), reverse([1, 2, 3])
say sort([3, 1, 2]), sort(["c", "a"])
say sum([1, 2, 3]), sum([1.5, 2])

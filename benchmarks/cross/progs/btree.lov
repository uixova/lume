struct Node:
    val = 0
    left = null
    right = null
fn make(d):
    if d == 0:
        return Node(1, null, null)
    return Node(1, make(d - 1), make(d - 1))
fn check(n):
    if n.left == null:
        return n.val
    return n.val + check(n.left) + check(n.right)
set total = 0
for i in range(8):
    set t = make(15)
    total = total + check(t)
say total
